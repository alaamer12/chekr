{
  "name": "@chekr/cli",
  "version": "0.2.3",
  "description": "Command-line interface for chekr — run project rules from the terminal",
  "license": "MIT",
  "type": "module",
  "author": "chekr contributors",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alaamer12/chekr.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/alaamer12/chekr/issues"
  },
  "homepage": "https://github.com/alaamer12/chekr/tree/main/packages/cli#readme",
  "keywords": [
    "chekr",
    "cli",
    "design-system",
    "rules",
    "ai",
    "linter"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "chekr": "src/index.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./engine": "./src/engine.js",
    "./utils": "./src/lib/utils/index.js",
    "./mesh": "./src/lib/utils/mesh-optimizer.js",
    "./helpers": "./src/lib/helpers/index.js",
    "./runner": "./src/lib/core/runner.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "node ../../scripts/verify-cli-pack.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "ignore": "^7.0.3",
    "simple-git": "^3.27.0"
  }
}
