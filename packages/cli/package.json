{
  "name": "@chekr/cli",
  "version": "0.1.0",
  "description": "Command-line interface for chekr — run project rules from the terminal",
  "license": "MIT",
  "type": "module",
  "author": "chekr contributors",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alaamer12/chekr.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/alaamer12/chekr/issues"
  },
  "homepage": "https://github.com/alaamer12/chekr/tree/main/packages/cli#readme",
  "keywords": [
    "chekr",
    "cli",
    "design-system",
    "rules",
    "ai",
    "linter"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "chekr": "./src/index.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./engine": "./src/engine.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
    "prepublishOnly": "node ../../scripts/prepare-cli-publish.mjs && node ../../scripts/verify-cli-pack.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@chekr/core": "0.1.0",
    "@chekr/helpers": "0.1.0",
    "@chekr/utils": "0.1.0",
    "ignore": "^7.0.3",
    "simple-git": "^3.27.0"
  },
  "bundledDependencies": [
    "@chekr/core",
    "@chekr/helpers",
    "@chekr/utils"
  ]
}
