{
  "name": "chekr",
  "version": "0.1.0",
  "private": true,
  "description": "AI output alignment checker — enforce design system contracts with plain JS rules",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alaamer12/chekr.git"
  },
  "bugs": {
    "url": "https://github.com/alaamer12/chekr/issues"
  },
  "homepage": "https://github.com/alaamer12/chekr#readme",
  "keywords": [
    "chekr",
    "ai",
    "design-system",
    "linter",
    "rules",
    "design-tokens",
    "contract"
  ],
  "bin": {
    "chekr": "./packages/cli/src/index.js"
  },
  "workspaces": [
    "packages/*",
    "types"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "3.2.4"
  },
  "scripts": {
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "bun run test:all",
    "test:helpers": "vitest run --config packages/helpers/vitest.config.js",
    "test:utils": "vitest run --config packages/utils/vitest.config.js",
    "test:core": "vitest run --config packages/core/vitest.config.js",
    "test:cli": "vitest run --config packages/cli/vitest.config.js",
    "test:types": "cd types && bun test",
    "test:all": "bun run test:helpers && bun run test:utils && bun run test:core && bun run test:cli && bun run test:types",
    "typecheck": "tsc -p types/tsconfig.json",
    "typecheck:types": "tsc -p types/tsconfig.json",
    "pack:cli": "node scripts/sync-cli-vendor.mjs && node scripts/verify-cli-pack.mjs",
    "smoke": "cd examples/minimal && node ../../packages/cli/src/index.js run",
    "verify": "bun run lint && bun run typecheck && bun run test:all && bun run smoke"
  }
}
